{
  "qweather_key": {
    "description": "和风天气 API Key",
    "type": "string",
    "default": "",
    "required": true,
    "obvious_hint": true
  },
  "api_host": {
    "description": "和风天气 API 主机地址",
    "type": "string",
    "default": "devapi.qweather.com",
    "hint": "默认使用免费订阅主机，付费订阅请填写 api.qweather.com"
  },
  "default_city": {
    "description": "默认查询城市",
    "type": "string",
    "default": "北京"
  },
  "timezone": {
    "description": "定时推送所用时区",
    "type": "string",
    "default": "Asia/Shanghai",
    "hint": "如 Asia/Shanghai、Asia/Tokyo、America/New_York 等"
  },
  "daily_push_time": {
    "description": "每日天气推送时间",
    "type": "string",
    "default": "08:00",
    "hint": "格式为 HH:MM，例如 08:00"
  },
  "whitelist_groups": {
    "description": "允许推送/响应的群聊白名单（填入完整会话标识符）",
    "type": "list",
    "hint": "格式为 平台名:消息类型:群号，如: napcat:GroupMessage:1350989414, telegram:GroupMessage:123456。留空则忽略白名单检查。",
    "default": []
  },
  "admin_users": {
    "description": "插件管理员 ID 列表",
    "type": "list",
    "default": [],
    "hint": "此处配置的用户可以使用 weather_config 等管理指令"
  },
  "llm_enabled": {
    "description": "是否启用 LLM 天气指南",
    "type": "bool",
    "default": false
  },
  "llm_provider": {
    "description": "LLM 提供商",
    "type": "string",
    "default": "openai"
  },
  "llm_api_key": {
    "description": "LLM API Key",
    "type": "string",
    "default": ""
  },
  "llm_base_url": {
    "description": "LLM API 地址",
    "type": "string",
    "default": "https://api.openai.com/v1/chat/completions"
  },
  "llm_model": {
    "description": "LLM 模型名称",
    "type": "string",
    "default": "gpt-4o-mini"
  },
  "holiday_cache_enabled": {
    "description": "是否启用节假日问候",
    "type": "bool",
    "default": true
  },
  "indices_types": {
    "description": "为llm配置请求的生活指数类型，将用于生成生活指南",
    "type": "string",
    "default": "1,3,5,6,7,8,9,10,11,14,15",
    "hint": "1: 运动,2: 洗车,3: 穿衣,4: 钓鱼,5: 紫外线,6: 旅游,7: 花粉过敏,8: 舒适度,9: 感冒,10: 空气污染扩散条件,11: 空调开启,12: 太阳镜,13: 化妆,14: 晾晒，15: 交通,16: 防晒"
  }
}
